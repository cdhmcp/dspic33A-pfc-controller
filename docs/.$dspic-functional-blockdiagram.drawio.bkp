  <diagram id="state-machine" name="State Machine">
    <mxGraphModel dx="2868" dy="1672" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="sm-title" value="PFC Power Control State Machine — PwrCtrl_PFC_Task_100us()" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#FFFFFF;" parent="1" vertex="1">
          <mxGeometry x="70" y="20" width="550" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sm-sub" value="Called every 100µs from Timer1 ISR via OS Scheduler" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#CCCCCC;" parent="1" vertex="1">
          <mxGeometry x="120" y="50" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sm-init" value="PCS_INIT (1)&#xa;&#xa;• initPFCComp()&#xa;• Initialize 2P2Z coefficients&#xa;• Reset compensator history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050EF;strokeColor=#0050EF;fontColor=#FFFFFF;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="235" y="120" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="sm-standby" value="PCS_STANDBY (2)&#xa;&#xa;• PG1DC = 0, PG2DC = 0 (PWM off)&#xa;• RegulationMode = DISABLED&#xa;• PFCCompReset()&#xa;• sftStrtInitVoltage = DISABLED&#xa;• relay_on_wait_cnt = 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050EF;strokeColor=#0050EF;fontColor=#FFFFFF;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="220" y="270" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sm-rwait" value="PCS_RELAYON_WAIT (3)&#xa;&#xa;• Wait for pfcStateFlags.RelayOn&#xa;• Wait 200ms (relay_on_wait_cnt)&#xa;• Wait for pfcVacSate == STATE_VAC_ZERO&#xa;  (zero-cross synchronization)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050EF;strokeColor=#0050EF;fontColor=#FFFFFF;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="210" y="470" width="250" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sm-sstart" value="PCS_SOFT_START (4)&#xa;&#xa;• SoftStart() ramps pfcVoltageRef&#xa;• Delta = (target - initial) / 500&#xa;• Increments every SOFT_START_COUNT&#xa;• Exits when Vref &gt;= PFCVOLTAGEREFADC&#xa;• Sets RegulationMode = ENABLED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050EF;strokeColor=#0050EF;fontColor=#FFFFFF;fontSize=10;align=center;" parent="1" vertex="1">
          <mxGeometry x="215" y="640" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sm-normal" value="PCS_NORMAL (5)&#xa;&#xa;• Full voltage + current regulation&#xa;• VRMS monitoring&#xa;• RMS power calculation&#xa;• PFC_OK signal management&#xa;• Continuous fault monitoring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050EF;strokeColor=#003399;fontColor=#FFFFFF;fontSize=10;align=center;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="215" y="840" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sm-off" value="PCS_OFF (6)&#xa;&#xa;• PG1DC = 0, PG2DC = 0 (PWM off)&#xa;• RegulationMode = DISABLED&#xa;• Fault lockout — requires&#xa;  power cycle or fault clear" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1A1A;strokeColor=#CC0000;fontColor=#FFFFFF;fontSize=10;align=center;strokeWidth=3;" parent="1" vertex="1">
          <mxGeometry x="650" y="840" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="st1" value="init done" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CCCCCC;fontColor=#FFFFFF;labelBackgroundColor=#333333;fontSize=10;" parent="1" source="sm-init" target="sm-standby" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st2" value="AC input valid&#xa;(CheckVacInputOK)&#xa;&amp; no faults" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CCCCCC;fontColor=#FFFFFF;labelBackgroundColor=#333333;fontSize=10;" parent="1" source="sm-standby" target="sm-rwait" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st3" value="Relay ON&#xa;+ 200ms delay&#xa;+ zero-cross sync" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CCCCCC;fontColor=#FFFFFF;labelBackgroundColor=#333333;fontSize=10;" parent="1" source="sm-rwait" target="sm-sstart" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st4" value="Vref ramp complete&#xa;RegulationMode = ENABLED" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CCCCCC;fontColor=#FFFFFF;labelBackgroundColor=#333333;fontSize=10;" parent="1" source="sm-sstart" target="sm-normal" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="st5" value="CheckVacInputOK() == false&#xa;(loss of AC input)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#666666;fontColor=#FFFFFF;labelBackgroundColor=#333333;fontSize=10;curved=1;entryX=0;entryY=0.75;entryDx=0;entryDy=0;" parent="1" source="sm-normal" target="sm-standby" edge="1">
