        <mxCell id="sm-always" value="Runs EVERY 100µs (all states):&#xa;&#xa;• ZeroCrossCheck(vacAvg)&#xa;• CheckVacInputOK() — brown-in 600ms / brown-out 30ms&#xa;• CheckPFCVoltage() — PFC_OK / NOT_OK hysteresis&#xa;• RelayControl() — GPIO RC8 based on AC valid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#CCCCCC;fontSize=10;align=left;spacingLeft=10;fontColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="570" y="120" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="sm-faults" value="pfcFaultFlags (any bit → PCS_OFF):&#xa;&#xa;MainsVoltage | MainsFreq | DrvSupply&#xa;MainsUnderVoltage | MainsOverVoltage&#xa;OutputUnderVoltage | OutputOverVoltage&#xa;OverCurrent | DCDCFaultMode&#xa;Communication | LowLineOverPower&#xa;HW_OutputOverVoltage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#CC0000;fontSize=10;align=left;spacingLeft=10;fontColor=#FFFFFF;strokeWidth=2;" parent="1" vertex="1">
