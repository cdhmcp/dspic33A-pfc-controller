        <mxCell id="st6" value="SystemFaults != 0" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#CC0000;fontColor=#FF6666;labelBackgroundColor=#1A1A1A;fontSize=10;strokeWidth=2;entryX=0;entryY=0.25;entryDx=0;entryDy=0;" parent="1" source="sm-standby" target="sm-off" edge="1">
          <mxGeometry relative="1" as="geometry">
